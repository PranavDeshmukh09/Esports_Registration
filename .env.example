# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.mongodb.net/?appName=AppName
MONGODB_URI=mongodb+srv://username:password@your-cluster.mongodb.net/?appName=BgmiTournament

# Razorpay Payment Gateway Keys
# Get these from: https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_SECRET_KEY

# Note: For special characters in password, URL-encode them:
# @ = %40
# # = %23
# etc.
